{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "types": []
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
