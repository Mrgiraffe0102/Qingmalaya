{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["@tarojs/taro", "node"],
    "paths": {
      "@qingmalaya/shared": ["../../packages/shared/src"],
      "@qingmalaya/shared/*": ["../../packages/shared/src/*"]
