{
  "name": "@qingmalaya/server",
  "version": "0.0.0",
  "private": true,
  "description": "万卷回响 NestJS backend API",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
