// 万卷回响 campus podcast platform — Prisma schema (MySQL).
//
// This is the full domain schema. Task 6 will verify/refine it; later tasks
// add the resource modules on top.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  OPERATOR
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum PodcastStatus {
  PENDING
  PUBLISHED
  TAKEN_DOWN
  FLAGGED
}

// TagColor stores lowercase color names in the DB to match
// @qingmalaya/shared TagColor values.
enum TagColor {
  mint
  purple
  orange
  rose
  sky
  teal
  indigo
  amber
}

enum CommentStatus {
  VISIBLE
  HIDDEN
}

enum LikeTargetType {
  PODCAST
  COMMENT
}

enum BannerLinkType {
  PODCAST
  PODCAST_LIST
  COLLECTION
  MARKDOWN
  NONE
}

enum BannerStatus {
  ONLINE
  OFFLINE
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}

enum NotificationType {
  BROADCAST
  PODCAST_APPROVED
  PODCAST_REJECTED
  PODCAST_LIKED
  PODCAST_COMMENTED
  PODCAST_FLAGGED
  COMMENT_REPORTED
}

enum ReviewAction {
  APPROVE
  FLAG
  REJECT
}

enum CommentReportStatus {
  PENDING
  RESOLVED
}

enum UserAction {
  PLAY
  LIKE_PODCAST
  UNLIKE_PODCAST
  FAVORITE
  UNFAVORITE
  LIKE_COMMENT
  UNLIKE_COMMENT
  CREATE_COMMENT
  DELETE_COMMENT
  CREATE_PODCAST
  UPDATE_PODCAST
  DELETE_PODCAST
  UPDATE_PROFILE
}

model User {
  id                 Int        @id @default(autoincrement())
  studentId          String     @unique
  name               String
  classId            Int?
  passwordHash       String
  role               Role       @default(STUDENT)
  avatar             String?
  bio                String?    @db.Text
  totalListens       Int        @default(0)
  totalLikes         Int        @default(0)
  status             UserStatus @default(ACTIVE)
  firstLogin         Boolean    @default(true)
  mustChangePassword Boolean    @default(true)
  manageAllClasses   Boolean    @default(false)
  isStudentAdmin     Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  class         Class?        @relation(fields: [classId], references: [id])
  podcasts      Podcast[]
  comments      Comment[]
  likes         Like[]
  favorites     Favorite[]
  playHistories PlayHistory[]
  adminLogs     AdminLog[]
  activityLogs  UserActivityLog[]
  notifications         Notification[] @relation("NotificationRecipient")
  triggeredNotifications Notification[] @relation("NotificationActor")
  teacherClasses TeacherClass[]
  podcastReviews     PodcastReview[]
  commentReports     CommentReport[]   @relation("CommentReporter")
  resolvedReports    CommentReport[]   @relation("CommentResolver")

  @@index([classId])
  @@index([role])
}

model Class {
  id         Int      @id @default(autoincrement())
  name       String
  grade      String?
  createdAt  DateTime @default(now())

  users         User[]
  podcasts      Podcast[]
  teacherClasses TeacherClass[]
}

model TeacherClass {
  teacherId Int
  classId   Int

  teacher User  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([teacherId, classId])
  @@index([classId])
}

model Podcast {
  id           Int           @id @default(autoincrement())
  title        String
  description  String?       @db.Text
  coverPath    String?
  audioPath    String
  duration     Int
  authorId     Int
  classId      Int?
  status       PodcastStatus @default(PENDING)
  playCount    Int           @default(0)
  likeCount    Int           @default(0)
  commentCount Int           @default(0)
  transcript   Json?
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  author      User          @relation(fields: [authorId], references: [id])
  class       Class?        @relation(fields: [classId], references: [id])
  tags        PodcastTag[]
  comments    Comment[]
  likes       Like[]
  favorites   Favorite[]
  PlayHistory PlayHistory[]
  collections CollectionPodcast[]
  notifications Notification[]
  reviews      PodcastReview[]

  @@index([authorId])
  @@index([classId])
  @@index([status])
  @@index([publishedAt])
  @@index([playCount])
  @@index([likeCount])
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  weight    Int      @default(0)
  color     TagColor @default(mint)
  createdAt DateTime @default(now())

  podcasts PodcastTag[]
}

model PodcastTag {
  podcastId Int
  tagId     Int
  podcast   Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([podcastId, tagId])
  @@index([tagId])
}

model Comment {
  id        Int           @id @default(autoincrement())
  podcastId Int
  userId    Int
  content   String        @db.Text
  parentId  Int?
  likeCount Int           @default(0)
  status    CommentStatus @default(VISIBLE)
  createdAt DateTime      @default(now())

  podcast Podcast   @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
  likes   Like[]
  reports CommentReport[]

  @@index([podcastId])
  @@index([userId])
  @@index([parentId])
}

model Like {
  id         Int            @id @default(autoincrement())
  userId     Int
  targetType LikeTargetType
  targetId   Int
  createdAt  DateTime       @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Podcast   Podcast? @relation(fields: [podcastId], references: [id])
  podcastId Int?
  Comment   Comment? @relation(fields: [commentId], references: [id])
  commentId Int?

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  podcastId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@unique([userId, podcastId])
}

model PlayHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  podcastId Int
  position  Int      @default(0)
  playedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@index([userId, podcastId])
}

model Banner {
  id              Int            @id @default(autoincrement())
  title           String
  coverPath       String
  linkType        BannerLinkType @default(NONE)
  linkTarget      String?
  markdownContent String?        @db.Text
  sort            Int            @default(0)
  status          BannerStatus   @default(ONLINE)
  startAt         DateTime?
  endAt           DateTime?
  createdAt       DateTime       @default(now())

  @@index([status, sort])
}

model Announcement {
  id          Int                @id @default(autoincrement())
  title       String
  content     String             @db.Text
  status      AnnouncementStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime           @default(now())

  @@index([status, publishedAt])
}

model AdminLog {
  id         Int      @id @default(autoincrement())
  adminId    Int
  action     String
  targetType String?
  targetId   Int?
  detail     Json?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model UserActivityLog {
  id         Int        @id @default(autoincrement())
  userId     Int
  action     UserAction
  targetType String?
  targetId   Int?
  detail     Json?
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([targetType, targetId])
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model BannedKeyword {
  id        Int      @id @default(autoincrement())
  keyword   String   @unique
  createdAt DateTime @default(now())
}

model Collection {
  id          Int          @id @default(autoincrement())
  title       String
  description String?      @db.Text
  coverPath   String?
  sort        Int          @default(0)
  status      BannerStatus @default(ONLINE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  podcasts CollectionPodcast[]

  @@index([status, sort])
}

model CollectionPodcast {
  collectionId Int
  podcastId    Int
  sort         Int @default(0)

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  podcast    Podcast    @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@id([collectionId, podcastId])
  @@index([podcastId])
}

model UploadedFile {
  id           Int      @id @default(autoincrement())
  filename     String
  originalName String
  path         String
  mimetype     String
  size         Int
  createdAt    DateTime @default(now())

  @@index([mimetype])
  @@index([createdAt])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  content   String           @db.Text
  podcastId Int?
  actorId   Int?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user    User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor   User?    @relation("NotificationActor", fields: [actorId], references: [id])
  podcast Podcast? @relation(fields: [podcastId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
}

model PodcastReview {
  id         Int          @id @default(autoincrement())
  podcastId  Int
  reviewerId Int
  action     ReviewAction
  reason     String?      @db.Text
  createdAt  DateTime     @default(now())

  podcast  Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  reviewer User    @relation(fields: [reviewerId], references: [id])

  @@index([podcastId])
  @@index([reviewerId])
}

model CommentReport {
  id           Int                 @id @default(autoincrement())
  commentId    Int
  reporterId   Int
  reason       String              @db.Text
  status       CommentReportStatus @default(PENDING)
  resolvedById Int?
  resolvedAt   DateTime?
  createdAt    DateTime            @default(now())

  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter  User    @relation("CommentReporter", fields: [reporterId], references: [id])
  resolver  User?   @relation("CommentResolver", fields: [resolvedById], references: [id])

  @@index([commentId])
  @@index([reporterId])
  @@index([status])
}

model AppRelease {
  id           Int      @id @default(autoincrement())
  version      String   @unique
  versionCode  Int      @unique
  updateContent String  @db.Text
  apkPath      String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

/// 全局强制弹窗（站点打开时第一时间弹出）。始终只有一条记录（id=1）。
/// enabled=false 表示禁用，弹窗不显示。记录本身保留以便管理员随时启用。
model Popup {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(120)
  content   String   @db.Text
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
