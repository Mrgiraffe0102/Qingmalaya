auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=true
# Hoist Metro / Expo / React Native packages to the top-level node_modules so
# that Metro 0.80.x's resolver can find transitive deps (e.g. metro-runtime
# used by @tarojs/rn-supporter/entry-file.js) which are otherwise nested deep
# inside node_modules/.pnpm/metro@<v>/node_modules/metro-runtime/.
public-hoist-pattern[]=metro
public-hoist-pattern[]=metro-*
public-hoist-pattern[]=@metro/*
public-hoist-pattern[]=expo
public-hoist-pattern[]=expo-*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=react-native
public-hoist-pattern[]=@react-native/*
